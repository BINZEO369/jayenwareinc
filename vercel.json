{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/components.js",
      "dest": "/public/components.js"
    },
    {
      "src": "/fonts.js",
      "dest": "/public/fonts.js"
    },
    {
      "src": "/hero-banner.js",
      "dest": "/public/hero-banner.js"
    },
    {
      "src": "/hero-video.js",
      "dest": "/public/hero-video.js"
    },
    {
      "src": "/hero-secondary-banner.js",
      "dest": "/public/hero-secondary-banner.js"
    },
    {
      "src": "/logo.png",
      "dest": "/public/logo.png"
    },
    {
      "src": "/auth-signup.html",
      "dest": "/public/auth-signup.html"
    },
    {
      "src": "/auth-login.html",
      "dest": "/public/auth-login.html"
    },
    {
      "src": "/product/(.*)",
      "dest": "/public/product.html"
    },
    {
      "src": "/category/(.*)",
      "dest": "/public/category.html"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|webp|mp4|webm|json|xml|txt))",
      "dest": "/public/$1"
    },
    {
      "src": "/products",
      "dest": "/public/index.html"
    },
    {
      "src": "/wishlist",
      "dest": "/public/index.html"
    },
    {
      "src": "/journal",
      "dest": "/public/index.html"
    },
    {
      "src": "/search",
      "dest": "/public/index.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
