{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/components.js",
      "dest": "/public/components.js"
    },
    {
      "src": "/logo.png",
      "dest": "/public/logo.png"
    },
    {
      "src": "/product/(.*)",
      "dest": "/public/product.html"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))",
      "dest": "/public/$1"
    },
    {
      "src": "/products",
      "dest": "/public/index.html"
    },
    {
      "src": "/wishlist",
      "dest": "/public/index.html"
    },
    {
      "src": "/journal",
      "dest": "/public/index.html"
    },
    {
      "src": "/category/(.*)",
      "dest": "/public/index.html"
    },
    {
      "src": "/search",
      "dest": "/public/index.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}

