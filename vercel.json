{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/product/(.*)",
      "dest": "/public/product.html"
    },
    {
      "src": "/products",
      "dest": "/public/index.html"
    },
    {
      "src": "/wishlist",
      "dest": "/public/index.html"
    },
    {
      "src": "/journal",
      "dest": "/public/index.html"
    },
    {
      "src": "/category/(.*)",
      "dest": "/public/index.html"
    },
    {
      "src": "/search",
      "dest": "/public/index.html"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
