{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/story", "destination": "/public/story.html" },
    { "source": "/signup", "destination": "/public/signup.html" },
    { "source": "/login", "destination": "/public/login.html" },
    { "source": "/faq", "destination": "/public/faq.html" },
    { "source": "/about", "destination": "/public/about.html" },
    { "source": "/blog", "destination": "/public/blog.html" },
    { "source": "/shipping-policy", "destination": "/public/shipping-policy.html" },
    { "source": "/return-policy", "destination": "/public/return-policy.html" },
    { "source": "/privacy-policy", "destination": "/public/privacy-policy.html" },
    { "source": "/terms-and-conditions", "destination": "/public/terms-and-conditions.html" },
    { "source": "/refund-policy", "destination": "/public/refund-policy.html" },
    { "source": "/cookie-policy", "destination": "/public/cookie-policy.html" },
    { "source": "/store-locator", "destination": "/public/store-locator.html" },
    { "source": "/product/:id", "destination": "/public/product.html" },
    { "source": "/category/:id", "destination": "/public/category.html" },
    { "source": "/products", "destination": "/public/index.html" },
    { "source": "/wishlist", "destination": "/public/index.html" },
    { "source": "/journal", "destination": "/public/index.html" },
    { "source": "/search", "destination": "/public/index.html" },
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}
